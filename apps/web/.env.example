# Public API base (no trailing slash). Production example:
NEXT_PUBLIC_API_BASE_URL=https://eam.techivano.com/api

# --- Convex + INTERNAL_JOB_SECRET (must align in THREE places) ---
#
# The deployment URL and secret must refer to the SAME Convex deployment
# (e.g. production). Mismatch → Convex rejects API calls (503 CONVEX_SECRET_MISMATCH
# on consent and other secret-guarded routes).
#
# 1) Vercel (Production): Project → Settings → Environment Variables
#    - NEXT_PUBLIC_CONVEX_URL = https://<your-deployment>.convex.cloud
#    - INTERNAL_JOB_SECRET = <shared secret string>
#
# 2) Convex Dashboard: Your project → Settings → Environment Variables
#    (same deployment as the URL above)
#    - INTERNAL_JOB_SECRET = <exact same value as Vercel>
#
# 3) Local dev: apps/web/.env.local (or repo root .env.local)
#    - NEXT_PUBLIC_CONVEX_URL = (same as Convex dev/prod URL you target)
#    - INTERNAL_JOB_SECRET = (same as Convex dashboard for that deployment)
#
# Rules: exact key name INTERNAL_JOB_SECRET; copy-paste the value once (no typos,
# no extra spaces). After changing Convex env vars, ensure deployment picked them up.
#
NEXT_PUBLIC_CONVEX_URL=
INTERNAL_JOB_SECRET=

# Optional: separate Express deployment for PDF + report email only. Rewrites
# /api/reports/mvp.pdf and /api/reports/mvp/email. Leave empty to keep all
# traffic on Next (Convex-backed routes). Do not set unless that API is deployed.
# Example: https://nmdpra-eam-api.vercel.app
BACKEND_API_ORIGIN=

# Clerk (https://dashboard.clerk.com) — required for dev/build
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Playwright integrated E2E — optional file `apps/web/.env.e2e.local` (gitignored)
# E2E_CLERK_EMAIL=            # required for integrated tests (ticket sign-in via @clerk/testing)
# E2E_ORG_ID=                 # fallback if Clerk user has no publicMetadata.orgId (upload tests)
# E2E_LAB_XLSX_PATH=          # optional: full path to a large .xlsx (asserts imported ≥ 200 rows)
# DEBUG_E2E=1                 # optional: log env resolution in Playwright (see e2e/load-test-env.ts)

# Excel upload → Vercel Blob (https://vercel.com/docs/storage/vercel-blob)
BLOB_READ_WRITE_TOKEN=

# Cron routes: Authorization: Bearer <secret> (Vercel Cron + manual triggers)
CRON_SECRET=

# Licence ingest mutation (Convex importLicenses)
INGEST_SECRET=

# Scheduled compliance emails (https://resend.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
