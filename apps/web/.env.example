# Public API base (no trailing slash). Production example:
NEXT_PUBLIC_API_BASE_URL=https://eam.techivano.com/api

# Convex deployment URL (Dashboard /api/reports/mvp, cron, upload). Set INTERNAL_JOB_SECRET
# to the same value in the Convex dashboard for secret-guarded queries/mutations.
NEXT_PUBLIC_CONVEX_URL=
INTERNAL_JOB_SECRET=

# Optional: separate Express deployment for PDF + report email only. Rewrites
# /api/reports/mvp.pdf and /api/reports/mvp/email. Leave empty to keep all
# traffic on Next (Convex-backed routes). Do not set unless that API is deployed.
# Example: https://nmdpra-eam-api.vercel.app
BACKEND_API_ORIGIN=

# Clerk (https://dashboard.clerk.com) — required for dev/build
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Excel upload → Vercel Blob (https://vercel.com/docs/storage/vercel-blob)
BLOB_READ_WRITE_TOKEN=

# Cron routes: Authorization: Bearer <secret> (Vercel Cron + manual triggers)
CRON_SECRET=

# Licence ingest mutation (Convex importLicenses)
INGEST_SECRET=

# Scheduled compliance emails (https://resend.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
