{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "@rmlis/shared": ["../../packages/shared/src/index"],
      "@rmlis/shared/*": ["../../packages/shared/src/*"],
      "@rmlis/reporting": ["../../services/reporting/src/index"],
      "@rmlis/reporting/*": ["../../services/reporting/src/*"]
    },
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["src"]
}
