DATABASE_URL=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
REPORT_EMAIL_TO=
REPORT_PDF_PATH=
FCM_SERVER_KEY=
CONVEX_URL=
CONVEX_TOKEN=
# Must match Convex dashboard INGEST_SECRET (used by pnpm ingest → importLicenses)
INGEST_SECRET=
# Client demo: comma-separated browser origins for CORS (omit for permissive dev default)
CORS_ORIGIN=
# Set to 1 behind a reverse proxy if you need correct client IPs
TRUST_PROXY=
# Set to 1 to include stack traces in JSON errors (never in production demos)
EXPOSE_ERROR_DETAILS=

# NODE_ENV is normally set by Vercel for production; do not set here unless you know why.
# NODE_ENV=

# --- Vercel / PDF (Chromium) ---
# Set on Vercel Project Settings; CONVEX_URL and Resend vars are required for API + PDF + email.
# Optional: local Chrome/Chromium path when not using @sparticuz/chromium default binary
# PUPPETEER_EXECUTABLE_PATH=
# CHROME_PATH=
