DATABASE_URL=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
REPORT_EMAIL_TO=
REPORT_PDF_PATH=
FCM_SERVER_KEY=
CONVEX_URL=
CONVEX_TOKEN=
# Must match Convex dashboard INGEST_SECRET (used by pnpm ingest → importLicenses)
INGEST_SECRET=
# Populate Convex from repo root (after CONVEX_URL + INGEST_SECRET are set):
#   pnpm ingest -- --json=data/nmdpra_data.sample.json
# Or use your own file: pnpm ingest -- --json=C:\path\to\nmdpra_data.json
# Excel (Windows): full path must include your user folder, e.g.
#   pnpm ingest -- --file="C:\Users\Windows\Downloads\Lab Accreditation Database 2025.xlsx"
# Or copy the file to data/lab.xlsx and: pnpm ingest -- --file=data/lab.xlsx
# Comma-separated browser origins allowed to call the API (required in production for dashboard fetch)
# Local dev: leave empty to allow all origins. Production: e.g. https://your-app.vercel.app
CORS_ORIGIN=
# Set to 1 behind a reverse proxy if you need correct client IPs
TRUST_PROXY=
# Set to 1 to include stack traces in JSON errors (never in production demos)
EXPOSE_ERROR_DETAILS=

# NODE_ENV is normally set by Vercel for production; do not set here unless you know why.
# NODE_ENV=

# --- Vercel / PDF (Chromium) ---
# Set on Vercel Project Settings; CONVEX_URL and Resend vars are required for API + PDF + email.
# Optional: local Chrome/Chromium path when not using @sparticuz/chromium default binary
# PUPPETEER_EXECUTABLE_PATH=
# CHROME_PATH=
