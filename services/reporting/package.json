{
  "name": "@rmlis/reporting",
  "version": "0.1.1",
  "private": true,
  "description": "RMLIS reporting service",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && node -e \"require('fs').cpSync('src/templates','dist/templates',{recursive:true})\"",
    "start": "node dist/index.js",
    "report:run": "tsx src/run-report.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./mvp": {
      "types": "./src/mvp/index.ts",
      "import": "./src/mvp/index.ts",
      "require": "./src/mvp/index.ts",
      "default": "./src/mvp/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts",
      "require": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "dependencies": {
    "@rmlis/shared": "workspace:*",
    "@sparticuz/chromium": "^143.0.4",
    "convex": "^1.34.1",
    "dotenv": "^17.3.1",
    "puppeteer-core": "^24.40.0",
    "resend": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
