{
  "name": "@rmlis/reporting",
  "version": "0.1.1",
  "private": true,
  "description": "PDF/report generation for Ivano IQ (MVP reports and templates).",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && node -e \"require('fs').cpSync('src/templates','dist/templates',{recursive:true})\"",
    "start": "node dist/index.js",
    "report:run": "tsx src/run-report.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./mvp": {
      "types": "./dist/mvp/index.d.ts",
      "import": "./dist/mvp/index.js",
      "require": "./dist/mvp/index.js"
    }
  },
  "dependencies": {
    "@rmlis/report-core": "workspace:*",
    "@rmlis/resend-client": "workspace:*",
    "@rmlis/shared": "workspace:*",
    "convex": "^1.34.1",
    "dotenv": "^17.3.1",
    "resend": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
